{
  "name": "@mgamil/slug-generator",
  "version": "1.6.1",
  "description": "A powerful, zero-dependency utility for generating cryptographically secure slugs and sanitizing arbitrary UTF-8 text into URL-safe formats with phonetic transliteration support.",
  "author": "Mohamed Gamil <mgamil.dev@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/MohamedGamil/slug-generator/tree/main/#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MohamedGamil/slug-generator.git"
  },
  "bugs": {
    "url": "https://github.com/MohamedGamil/slug-generator/issues"
  },
  "keywords": [
    "slug",
    "slugify",
    "slug-generator",
    "cryptographically-secure",
    "transliteration",
    "romanization",
    "phonetic",
    "unicode",
    "url-safe",
    "zero-dependencies",
    "uuid",
    "uuidv4",
    "uuidv6",
    "snowflake",
    "snowflake-id",
    "bloom-filter",
    "unique-slug",
    "obfuscate-counter",
    "slug-pool",
    "reversible-slug",
    "reversible-obfuscation",
    "decode-slug",
    "batch-slugs",
    "rejection-sampling",
    "bias-free",
    "base64url",
    "murmurhash"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "@types/node": "^20.11.0"
  }
}
